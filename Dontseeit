-- // FUSION / DUEL CHECKS
local function isFusing(animalData)
	if animalData.Machine and animalData.Machine.Type == "Fuse" and animalData.Machine.Active then
		return true
	end
	return false
end

local function isInDuel(animalData)
	local data = animalData.Data or animalData
	if animalData.Machine and type(animalData.Machine) == "table" then
		local mType = animalData.Machine.Type
		if type(mType) == "string" and mType:lower():find("duel") then
			return true
		end
	end
	if data and type(data) == "table" and data.Machine and type(data.Machine) == "table" then
		local mType = data.Machine.Type
		if type(mType) == "string" and mType:lower():find("duel") then
			return true
		end
	end
	if animalData.InDuel == true or animalData.inDuel == true or animalData.in_duel == true then
		return true
	end
	if type(data) == "table" and (data.InDuel == true or data.inDuel == true) then
		return true
	end
	return false
end

local function cameBackFromDuel(player)
	if player == LocalPlayer then
		local ok, data = pcall(function()
			return TeleportService:GetLocalPlayerTeleportData()
		end)
		if ok and type(data) == "table" and (data.fromDuel or data.DuelData or data.duel) then
			return true
		end
	end

	for _, child in ipairs(player:GetChildren()) do
		local lower = child.Name:lower()
		if lower:find("duel") or lower:find("returned") then
			return true
		end
	end

	local attrsOk, attrs = pcall(function()
		return player:GetAttributes()
	end)
	if attrsOk and attrs then
		for key, val in pairs(attrs) do
			local keyLower = tostring(key):lower()
			if (keyLower:find("duel") or keyLower:find("returned")) and (val == true or val == 1) then
				return true
			end
		end
	end

	return false
end

local function getPlotOwner(plot)
	local owner = plot:GetAttribute("Owner") or plot:GetAttribute("PlayerName") or plot.Name
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Name == owner or tostring(player.UserId) == tostring(owner) then
			return player
		end
	end
	return nil
end

local function getDuelPlayers()
	local duelPlayers = {}
	for _, player in ipairs(Players:GetPlayers()) do
		if cameBackFromDuel(player) then
			duelPlayers[player.Name] = true
			duelPlayers[tostring(player.UserId)] = true
		end
	end
	return duelPlayers
end

local function isPlotOwnerInDuel(plot, duelPlayers)
	local owner = plot:GetAttribute("Owner") or plot:GetAttribute("PlayerName") or plot.Name
	if duelPlayers[owner] or duelPlayers[tostring(owner)] then
		return true
	end
	local player = getPlotOwner(plot)
	if player and (duelPlayers[player.Name] or duelPlayers[tostring(player.UserId)]) then
		return true
	end
	return false
end

-- // ESCANEO CARPET
local function scanCarpet(seen, currentJobId)
	local results = {}

	for _, instance in ipairs(Workspace:GetChildren()) do
		if instance.ClassName ~= "Model" then
			continue
		end

		local name = instance:GetAttribute("Index")
		if not name or not animalsData[name] then
			continue
		end

		local mutation = instance:GetAttribute("Mutation")
		if type(mutation) ~= "string" or mutation == "" then
			mutation = nil
		end

		local traitsTable = nil
		local traitsList = {}
		local traitsRaw = instance:GetAttribute("Traits")
		if traitsRaw and type(traitsRaw) == "string" then
			local ok, decoded = pcall(HttpService.JSONDecode, HttpService, traitsRaw)
			if ok and type(decoded) == "table" then
				traitsTable = {}
				if #decoded > 0 then
					for _, trait in ipairs(decoded) do
						if type(trait) == "string" then
							table.insert(traitsTable, trait)
							table.insert(traitsList, trait)
						end
					end
				else
					for traitName, enabled in pairs(decoded) do
						if enabled then
							table.insert(traitsTable, traitName)
							table.insert(traitsList, traitName)
						end
					end
				end
				if #traitsTable == 0 then
					traitsTable = nil
				end
			end
		end

		if instance:GetAttribute("Fusing") == true then
			continue
		end

		local okGen, genValue = pcall(function()
			return animalsShared:GetGeneration(name, mutation, traitsTable, nil)
		end)
		if not okGen or type(genValue) ~= "number" then
			continue
		end

		if not shouldScan(genValue) then
			continue
		end

		local tier = getTier(genValue)
		local genText = "$" .. numberUtils:ToString(genValue) .. "/s"
		local key = "carpet:" .. name .. ":" .. genText
		if seen[key] then
			continue
		end
		seen[key] = true

		if hasBeenLogged(currentJobId, name, genText) then
			continue
		end

		table.insert(results, {
			tier = tier,
			name = name,
			money = genText,
			numeric = genValue,
			mutation = mutation,
			traits = #traitsList > 0 and traitsList or nil,
			traitCount = traitsTable and #traitsTable or 0,
			isFusing = false,
			inDuel = false,
			isCarpet = true,
			isContext = false,
		})
	end

	return results
end

-- // ESCANEO PLOTS (CON DUELS)
local function scanPlots(duelPlayers, seen, currentJobId)
	local results = {}
	local plots = Workspace:FindFirstChild("Plots")
	if not plots then
		return results
	end

	for _, plot in ipairs(plots:GetChildren()) do
		local okPot, pot = pcall(function()
			return sync:Get(plot.Name)
		end)
		if not okPot or not pot then
			continue
		end

		local okList, list = pcall(function()
			return pot:Get("AnimalList")
		end)
		if not okList or type(list) ~= "table" then
			continue
		end

		local syncOwner = nil
		local ownerOk, ownerVal = pcall(function()
			return pot:Get("Owner")
		end)
		if ownerOk and ownerVal ~= nil then
			syncOwner = tostring(ownerVal)
		end

		local plotDuel = false
		if syncOwner and type(syncOwner) == "string" then
			if duelPlayers[syncOwner] then
				plotDuel = true
			end
		else
			plotDuel = isPlotOwnerInDuel(plot, duelPlayers)
		end

		local plotItems = {}
		local plotHasQualifying = false

		for _, animalData in pairs(list) do
			if type(animalData) ~= "table" then
				continue
			end
			if isFusing(animalData) then
				continue
			end

			local inDuel = isInDuel(animalData) or plotDuel
			local name = animalData.Index
			if not name or not animalsData[name] then
				continue
			end

			local data = animalData.Data or animalData
			local mutation = data.Mutation
			if type(mutation) ~= "string" or mutation == "" then
				mutation = nil
			end

			local traitsTable = nil
			local traitsList = {}
			if type(data.Traits) == "table" then
				traitsTable = {}
				if #data.Traits > 0 then
					for _, trait in ipairs(data.Traits) do
						if type(trait) == "string" then
							table.insert(traitsTable, trait)
							table.insert(traitsList, trait)
						end
					end
				else
					for traitName, enabled in pairs(data.Traits) do
						if enabled then
							table.insert(traitsTable, traitName)
							table.insert(traitsList, traitName)
						end
					end
				end
				if #traitsTable == 0 then
					traitsTable = nil
				end
			end

			local okGen, genValue = pcall(function()
				return animalsShared:GetGeneration(name, mutation, traitsTable, nil)
			end)
			if not okGen or type(genValue) ~= "number" then
				continue
			end

			local qualifies = shouldScan(genValue)
			if qualifies then
				plotHasQualifying = true
			end

			table.insert(plotItems, {
				name = name,
				genValue = genValue,
				mutation = mutation,
				traitsList = traitsList,
				traitCount = traitsTable and #traitsTable or 0,
				inDuel = inDuel,
				qualifies = qualifies,
			})
		end

		if not plotHasQualifying then
			continue
		end

		for _, item in ipairs(plotItems) do
			local genText = "$" .. numberUtils:ToString(item.genValue) .. "/s"
			local key = "plot:" .. item.name .. ":" .. genText
			if seen[key] then
				continue
			end
			seen[key] = true

			if hasBeenLogged(currentJobId, item.name, genText) then
				continue
			end

			table.insert(results, {
				tier = getTier(item.genValue),
				name = item.name,
				money = genText,
				numeric = item.genValue,
				mutation = item.mutation,
				traits = #item.traitsList > 0 and item.traitsList or nil,
				traitCount = item.traitCount,
				isFusing = false,
				inDuel = item.inDuel,
				isCarpet = false,
				isContext = not item.qualifies,
			})
		end
	end

	return results
end

local function scanAll()
	local seen = {}
	local currentJobId = game.JobId
	local duelPlayers = getDuelPlayers()

	local plotResults = scanPlots(duelPlayers, seen, currentJobId)
	local carpetResults = scanCarpet(seen, currentJobId)

	local allResults = {}
	for _, item in ipairs(plotResults) do
		table.insert(allResults, item)
	end
	for _, item in ipairs(carpetResults) do
		table.insert(allResults, item)
	end

	table.sort(allResults, function(a, b)
		return a.numeric > b.numeric
	end)

	return allResults
end

local function sourceLabel(item)
	if item.isCarpet then
		return "carpet"
	end
	return "plot"
end

