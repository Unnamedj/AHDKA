					{ name = "⚔️ In Duel", value = bestDuel, inline = true },
					{ name = "👥 Players", value = pCount, inline = false },
					{ name = "Job ID (Mobile)", value = "`" .. jid .. "`", inline = false },
					{ name = "Job ID (PC)", value = "```" .. jid .. "```", inline = false },
					{ name = "Join Script (PC)", value = "```" .. jCode .. "```", inline = false },
					{ name = "🧠 Brainrots", value = brainrotList, inline = false },
				},
				footer = { text = EMBED_BRAND },
			},
		},
	}

	pcall(function()
		requestFunc({
			Url = hook,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = HttpService:JSONEncode(payload),
		})
	end)

	for _, item in ipairs(allItems) do
		markAsLogged(jid, item.name, item.money)
	end
end

