-- // UTILIDADES
local function formatNum(n)
	if n >= 1e9 then
		return string.format("%.2fB", n / 1e9)
	elseif n >= 1e6 then
		return string.format("%.2fM", n / 1e6)
	elseif n >= 1e3 then
		return string.format("%.2fK", n / 1e3)
	else
		return tostring(math.floor(n))
	end
end

local function shouldScan(value)
	return value >= MIN_REPORT_VALUE
end

local function getTier(v)
	if v >= 1e9 then
		return "1b"
	elseif v >= 400e6 then
		return "400m"
	elseif v >= 100e6 then
		return "100m"
	elseif v >= 10e6 then
		return "10m"
	end
	return "low"
end

