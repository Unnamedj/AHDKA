-- // API HOPPER — /get-job (?wait= espera si la cola está vacía; ?key= autentica aunque el executor ignore headers)
local function hop()
	while true do
		print("[HOP] Solicitando nuevo servidor...")
		local ok, response = pcall(function()
			return requestFunc({
				Url = getJobUrl(8),
				Method = "GET",
				Headers = hubHeadersGet(),
			})
		end)

		local sc = ok and response and response.StatusCode
		local body = ok and response and type(response.Body) == "string" and response.Body or ""

		if ok and response and sc == 200 then
			local decodeOk, data = pcall(function()
				return HttpService:JSONDecode(body)
			end)
			if decodeOk and data and data.id and data.empty ~= true then
				local targetJobId = tostring(data.id)
				local isGuidLike = targetJobId:match("^[%w%-]+$") ~= nil
				local isUsable = isGuidLike and targetJobId ~= "" and targetJobId ~= game.JobId and not failedJobIds[targetJobId]
				if isUsable then
					lastAttemptedJobId = targetJobId
					print("[HOP] Teleport a JobID:", targetJobId:sub(1, 8), "...")
					TeleportService:TeleportToPlaceInstance(PLACE_ID, targetJobId, LocalPlayer)
					return
				end
			elseif decodeOk and data and data.empty == true then
				print("[HOP] Cola vacía (nadie ha reportado servidores al hub). Espera scanners o revisa API_KEY en VPS.")
			end
		elseif sc == 401 then
			warn("[HOP] 401 Unauthorized — VULTR_API_KEY no coincide con el .env del servidor (o falta ?key=).")
		elseif sc == 404 then
			print("[HOP] 404 Cola vacía (modo legacy). Reintentando...")
		else
			warn("[HOP] Respuesta rara StatusCode=", tostring(sc), " body=", body:sub(1, 120))
		end

		task.wait(3)
	end
end

