-- // FUNCION ANTI-DETECCION (BYPASS SYNCHRONIZER)
local function safeRequire(module)
	local get_thread_identity = getthreadidentity or getidentity or function() return 2 end
	local set_thread_identity = setthreadidentity or setidentity or function() end
	
	local success, result = pcall(function()
		local currentIdentity = get_thread_identity()
		set_thread_identity(2) -- Engaña al juego haciéndole creer que es un LocalScript normal
		local req = require(module)
		set_thread_identity(currentIdentity) -- Restaura la identidad del executor
		return req
	end)
	
	if success then
		return result
	else
		return require(module) -- Fallback en caso de error
	end
end

